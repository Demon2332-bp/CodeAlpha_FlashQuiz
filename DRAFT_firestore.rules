rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    function isValidQuiz(data) {
      return data.keys().hasAll(['adminId', 'title', 'subject', 'timerPerQuestion', 'questions', 'createdAt']) && 
             data.keys().size() == 6 &&
             data.adminId is string && data.adminId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.subject is string && data.subject.size() <= 50 &&
             data.timerPerQuestion is number && data.timerPerQuestion > 0 && data.timerPerQuestion <= 120 &&
             data.questions is list && data.questions.size() <= 50 &&
             data.createdAt is number;
    }

    function isValidSessionCreate(data) {
      return data.keys().hasAll(['adminId', 'quizId', 'status', 'currentQuestionIndex', 'questionEndTime', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.adminId is string && data.adminId == request.auth.uid &&
             data.quizId is string && 
             data.status is string && data.status == 'waiting' &&
             data.currentQuestionIndex is number && data.currentQuestionIndex == 0 &&
             data.questionEndTime is number &&
             data.createdAt is number;
    }

    function isValidParticipant(data) {
      return data.keys().hasAll(['name', 'score', 'answers', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 30 &&
             data.score is number && 
             data.answers is map &&
             data.createdAt is number;
    }

    match /quizzes/{quizId} {
      allow read: if isValidId(quizId); // public to read so players can get questions and sessions can pull it
      allow create: if isSignedIn() && isValidId(quizId) && isValidQuiz(incoming());
      allow update: if isSignedIn() && isOwner(existing().adminId) && isValidQuiz(incoming()) && incoming().adminId == existing().adminId && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && isOwner(existing().adminId);
    }

    match /sessions/{sessionId} {
      allow read: if isValidId(sessionId); // anyone can read to join
      allow create: if isSignedIn() && isValidId(sessionId) && isValidSessionCreate(incoming());
      
      allow update: if isSignedIn() && isOwner(existing().adminId) && incoming().adminId == existing().adminId && incoming().quizId == existing().quizId && incoming().createdAt == existing().createdAt && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'currentQuestionIndex', 'questionEndTime']))
      );
      allow delete: if isSignedIn() && isOwner(existing().adminId);

      match /participants/{participantId} {
        // Unauthenticated users can read to see leaderboard
        // Unauthenticated users can join (create) and update their scores
        // We relax auth checks here for demo Kahoot style
        allow read: if isValidId(participantId);
        allow create: if isValidId(participantId) && isValidParticipant(incoming());
        allow update: if isValidId(participantId) && isValidParticipant(incoming()) && incoming().name == existing().name && incoming().createdAt == existing().createdAt && 
          incoming().diff(existing()).affectedKeys().hasOnly(['score', 'answers']);
        allow delete: if isSignedIn() && isOwner(get(/databases/$(database)/documents/sessions/$(sessionId)).data.adminId);
      }
    }
  }
}
